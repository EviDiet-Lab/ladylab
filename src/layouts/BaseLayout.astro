---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
}

const {
  title,
  description,
  image,
  type = 'website',
  publishedTime,
} = Astro.props;
const siteName = 'LadyLab';
const siteUrl = 'https://EviDiet-Lab.github.io/ladylab';
const pageUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImage = image || 'https://picsum.photos/seed/ladylab-default/1200/630';
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={pageUrl} />

    <!-- OGP -->
    <meta property="og:title" content={`${title} | ${siteName}`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | ${siteName}`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD: サイト全体 -->
    <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": siteName,
      "url": siteUrl,
      "description": description,
    })}
    </script>

    <!-- JSON-LD: パンくずリスト（固定） -->
    <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": siteUrl },
        ...(Astro.url.pathname !== "/" ? [
          { "@type": "ListItem", "position": 2, "name": title, "item": pageUrl }
        ] : [])
      ]
    })}
    </script>

    {type === 'article' && publishedTime && (
      <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": title,
        "description": description,
        "image": ogImage,
        "datePublished": publishedTime,
        "author": { "@type": "Organization", "name": "EviDiet-Lab" },
      })}
      </script>
    )}

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;600;700&display=swap" rel="stylesheet" />

    <!-- Design System -->
    <style is:global>
      @import '../styles/design-system.css';
    </style>

    <link rel="icon" type="image/svg+xml" href="/ladylab/favicon.svg" />

    <!-- Google Analytics -->
    <script>
      const gaId = typeof __GA_ID__ !== 'undefined' ? __GA_ID__ : '';
      if (gaId) {
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', gaId);
      }
    </script>
    {typeof __GA_ID__ !== 'undefined' && __GA_ID__ && (
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${__GA_ID__}`}></script>
    )}
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
